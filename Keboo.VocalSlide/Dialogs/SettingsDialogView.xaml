<UserControl x:Class="Keboo.VocalSlide.Dialogs.SettingsDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Keboo.VocalSlide"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=local:MainWindowViewModel, IsDesignTimeCreatable=False}"
             Width="560"
             MinHeight="400"
             MaxHeight="700">
  <materialDesign:Card UniformCornerRadius="4">
    <DockPanel LastChildFill="True">

      <materialDesign:ColorZone DockPanel.Dock="Top"
                                Mode="PrimaryMid"
                                Padding="16,10">
        <DockPanel>
          <Button DockPanel.Dock="Right"
                  Style="{StaticResource MaterialDesignIconForegroundButton}"
                  Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                  ToolTip="Close">
            <materialDesign:PackIcon Kind="Close" />
          </Button>
          <TextBlock Text="Settings"
                     VerticalAlignment="Center"
                     Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                     Foreground="White" />
        </DockPanel>
      </materialDesign:ColorZone>

      <ScrollViewer DockPanel.Dock="Bottom"
                    VerticalScrollBarVisibility="Auto"
                    Padding="16">
        <StackPanel Margin="20">

          <TextBlock FontWeight="SemiBold"
                     Text="Model storage folder"
                     Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                     Margin="0,0,0,4" />
          <TextBlock Margin="0,0,0,8"
                     Text="Downloaded model files are stored in %LOCALAPPDATA%\Keboo.VocalSlide."
                     TextWrapping="Wrap"
                     Style="{StaticResource MaterialDesignCaptionTextBlock}" />
          <DockPanel Margin="0,0,0,16">
            <Button DockPanel.Dock="Right"
                    Content="Open Folder"
                    Command="{Binding OpenModelFolderCommand}"
                    Margin="8,0,0,0" />
            <TextBox Text="{Binding ModelStorageDirectory}"
                     IsReadOnly="True"
                     materialDesign:HintAssist.Hint="Model folder path" />
          </DockPanel>

          <TextBlock FontWeight="SemiBold"
                     Text="Whisper model"
                     Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                     Margin="0,0,0,4" />
          <ComboBox Margin="0,0,0,4"
                    ItemsSource="{Binding WhisperDownloadOptions}"
                    SelectedItem="{Binding SelectedWhisperDownloadOption}"
                    DisplayMemberPath="DisplayName"
                    materialDesign:HintAssist.Hint="Select model size" />
          <DockPanel Margin="0,0,0,4">
            <Button DockPanel.Dock="Right"
                    Content="Download"
                    Command="{Binding DownloadWhisperModelCommand}"
                    Margin="8,0,0,0" />
            <TextBox Text="{Binding WhisperModelPath, UpdateSourceTrigger=PropertyChanged}"
                     materialDesign:HintAssist.Hint="Path to .bin file" />
          </DockPanel>
          <TextBlock Text="{Binding WhisperDownloadStatus}"
                     TextWrapping="Wrap"
                     Style="{StaticResource MaterialDesignCaptionTextBlock}" />
          <ProgressBar Height="4"
                       Minimum="0"
                       Maximum="100"
                       Value="{Binding WhisperDownloadPercent}"
                       Margin="0,4,0,16" />

          <TextBlock FontWeight="SemiBold"
                     Text="Ollama connection"
                     Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                     Margin="0,0,0,4" />
          <TextBox Margin="0,0,0,4"
                   Text="{Binding OllamaEndpoint, UpdateSourceTrigger=PropertyChanged}"
                   materialDesign:HintAssist.Hint="Ollama endpoint URL" />
          <TextBox Margin="0,0,0,16"
                   Text="{Binding OllamaModelName, UpdateSourceTrigger=PropertyChanged}"
                   materialDesign:HintAssist.Hint="Model name (e.g. qwen2.5:0.5b)" />

          <Separator Margin="0,0,0,16" />

          <TextBlock FontWeight="SemiBold"
                     Text="Inference settings"
                     Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                     Margin="0,0,0,8" />

          <TextBlock Text="Transcript language" />
          <TextBox Margin="0,4,0,12"
                   Text="{Binding TranscriptionLanguage, UpdateSourceTrigger=PropertyChanged}"
                   materialDesign:HintAssist.Hint="e.g. en" />

          <TextBlock Text="Indexed prompt slides" />
          <TextBox Margin="0,4,0,12"
                   Text="{Binding IndexedPromptSlideCount}"
                   IsReadOnly="True" />

          <TextBlock Text="Confidence threshold (0.0 – 1.0)" />
          <TextBox Margin="0,4,0,12"
                   Text="{Binding ConfidenceThreshold, UpdateSourceTrigger=PropertyChanged}" />

          <TextBlock Text="Cooldown seconds" />
          <TextBox Margin="0,4,0,16"
                   Text="{Binding DecisionCooldownSeconds, UpdateSourceTrigger=PropertyChanged}" />

        </StackPanel>
      </ScrollViewer>

    </DockPanel>
  </materialDesign:Card>
</UserControl>

<Window x:Class="Keboo.VocalSlide.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Keboo.VocalSlide"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=local:MainWindowViewModel, IsDesignTimeCreatable=False}"
        Style="{StaticResource MaterialDesignWindow}"
        Title="VocalSlide"
        Height="680"
        Width="900"
        MinWidth="640"
        MinHeight="480">

  <materialDesign:DialogHost Identifier="RootDialog">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="220" />
      </Grid.RowDefinitions>

      <!-- Header bar -->
      <materialDesign:ColorZone Grid.Row="0"
                                Mode="PrimaryMid"
                                Padding="16,10">
        <DockPanel>
          <Button DockPanel.Dock="Right"
                  Style="{StaticResource MaterialDesignIconForegroundButton}"
                  Command="{Binding OpenSettingsDialogCommand}"
                  ToolTip="Settings">
            <materialDesign:PackIcon Kind="Cog"
                                     Width="22"
                                     Height="22" />
          </Button>
          <TextBlock Text="VocalSlide — PowerPoint Auto Advance"
                     VerticalAlignment="Center"
                     Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                     Foreground="White" />
        </DockPanel>
      </materialDesign:ColorZone>

      <!-- Main area: Start / Stop / Pause / Resume -->
      <Grid Grid.Row="1">
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="360">

          <!-- START panel (visible when not running) -->
          <Button Command="{Binding StartAutomationCommand}"
                  Visibility="{Binding IsAutomationRunning, Converter={StaticResource InvBoolToVis}}"
                  Height="76"
                  Style="{StaticResource MaterialDesignRaisedButton}"
                  HorizontalAlignment="Stretch">
            <StackPanel Orientation="Horizontal">
              <materialDesign:PackIcon Kind="Play"
                                       Width="30"
                                       Height="30"
                                       VerticalAlignment="Center" />
              <TextBlock Text="START"
                         VerticalAlignment="Center"
                         Margin="12,0,0,0"
                         FontSize="20"
                         FontWeight="Bold" />
            </StackPanel>
          </Button>

          <!-- STOP / PAUSE / RESUME panel (visible when running) -->
          <Grid Visibility="{Binding IsAutomationRunning, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="8" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Command="{Binding StopAutomationCommand}"
                    Height="68"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="{DynamicResource MaterialDesignValidationErrorColor}"
                    BorderBrush="{DynamicResource MaterialDesignValidationErrorColor}"
                    Foreground="White">
              <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="Stop"
                                         Width="24"
                                         Height="24"
                                         VerticalAlignment="Center" />
                <TextBlock Text="STOP"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           FontSize="16"
                           FontWeight="SemiBold" />
              </StackPanel>
            </Button>

            <!-- PAUSE button (visible when not paused) -->
            <Button Grid.Column="2"
                    Command="{Binding PauseCommand}"
                    Visibility="{Binding IsPaused, Converter={StaticResource InvBoolToVis}}"
                    Height="68"
                    Style="{StaticResource MaterialDesignRaisedButton}">
              <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="Pause"
                                         Width="24"
                                         Height="24"
                                         VerticalAlignment="Center" />
                <TextBlock Text="PAUSE"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           FontSize="16"
                           FontWeight="SemiBold" />
              </StackPanel>
            </Button>

            <!-- RESUME button (visible when paused) -->
            <Button Grid.Column="2"
                    Command="{Binding ResumeCommand}"
                    Visibility="{Binding IsPaused, Converter={StaticResource BoolToVis}}"
                    Height="68"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="{DynamicResource MaterialDesignLightForegroundBrush}">
              <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="PlayCircle"
                                         Width="24"
                                         Height="24"
                                         VerticalAlignment="Center" />
                <TextBlock Text="RESUME"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           FontSize="16"
                           FontWeight="SemiBold" />
              </StackPanel>
            </Button>
          </Grid>

          <!-- Status message -->
          <TextBlock Text="{Binding StatusMessage}"
                     TextWrapping="Wrap"
                     TextAlignment="Center"
                     Margin="0,20,0,0"
                     Style="{StaticResource MaterialDesignBody2TextBlock}"
                     Opacity="0.75" />

        </StackPanel>
      </Grid>

      <!-- Bottom status GroupBox -->
      <GroupBox Grid.Row="2"
                Header="Status"
                Margin="12,0,12,12">
        <Grid Margin="8,4,8,4">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"
                              MinWidth="180" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="220" />
          </Grid.ColumnDefinitions>

          <!-- Presentation info -->
          <DockPanel Grid.Column="0"
                     LastChildFill="False">
            <Button DockPanel.Dock="Bottom"
                    Content="View Slides"
                    Command="{Binding OpenSlidesDialogCommand}"
                    Visibility="{Binding IsPowerPointConnected, Converter={StaticResource BoolToVis}}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Margin="0,6,0,0"
                    HorizontalAlignment="Left" />
            <StackPanel DockPanel.Dock="Top">
              <TextBlock Text="{Binding PresentationName}"
                         FontWeight="SemiBold"
                         TextTrimming="CharacterEllipsis"
                         ToolTip="{Binding PresentationName}" />
              <TextBlock Text="{Binding SlideShowStateText}"
                         TextWrapping="Wrap"
                         Margin="0,2,0,0"
                         Style="{StaticResource MaterialDesignCaptionTextBlock}" />
              <TextBlock Text="{Binding CurrentSlideTitle}"
                         TextWrapping="Wrap"
                         Margin="0,2,0,0"
                         Style="{StaticResource MaterialDesignCaptionTextBlock}" />
              <TextBlock Text="{Binding NextSlideTitle}"
                         TextWrapping="Wrap"
                         Margin="0,2,0,0"
                         Style="{StaticResource MaterialDesignCaptionTextBlock}"
                         Opacity="0.7" />
            </StackPanel>
          </DockPanel>

          <!-- Live transcript -->
          <DockPanel Grid.Column="2"
                     LastChildFill="True">
            <DockPanel DockPanel.Dock="Top"
                       Margin="0,0,0,4">
              <Button DockPanel.Dock="Right"
                      Style="{StaticResource MaterialDesignFlatButton}"
                      Command="{Binding ClearTranscriptCommand}"
                      Padding="4,0"
                      Height="22"
                      VerticalAlignment="Center">
                <TextBlock Text="Clear"
                           FontSize="10" />
              </Button>
              <TextBlock Text="Transcript"
                         FontWeight="SemiBold"
                         VerticalAlignment="Center"
                         Style="{StaticResource MaterialDesignCaptionTextBlock}" />
            </DockPanel>
            <TextBox Text="{Binding TranscriptWindow}"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     FontSize="11" />
          </DockPanel>

          <!-- Latest decision -->
          <DockPanel Grid.Column="4"
                     LastChildFill="True">
            <TextBlock DockPanel.Dock="Top"
                       Text="Latest Decision"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4"
                       Style="{StaticResource MaterialDesignCaptionTextBlock}" />
            <TextBox Text="{Binding LastDecision}"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     FontSize="11" />
          </DockPanel>

        </Grid>
      </GroupBox>

    </Grid>
  </materialDesign:DialogHost>

</Window>


<UserControl x:Class="Keboo.VocalSlide.Dialogs.SlidesDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Keboo.VocalSlide"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=local:MainWindowViewModel, IsDesignTimeCreatable=False}"
             Width="760"
             Height="540">
  <materialDesign:Card UniformCornerRadius="4">
    <DockPanel LastChildFill="True">

      <materialDesign:ColorZone DockPanel.Dock="Top"
                                Mode="PrimaryMid"
                                Padding="16,10">
        <DockPanel>
          <Button DockPanel.Dock="Right"
                  Style="{StaticResource MaterialDesignIconForegroundButton}"
                  Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                  ToolTip="Close">
            <materialDesign:PackIcon Kind="Close" />
          </Button>
          <Button DockPanel.Dock="Right"
                  Style="{StaticResource MaterialDesignIconForegroundButton}"
                  Command="{Binding RefreshPowerPointCommand}"
                  ToolTip="Refresh slides from PowerPoint"
                  Margin="0,0,4,0">
            <materialDesign:PackIcon Kind="Refresh" />
          </Button>
          <TextBlock Text="Slides and Automation Prompts"
                     VerticalAlignment="Center"
                     Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                     Foreground="White" />
        </DockPanel>
      </materialDesign:ColorZone>

      <Border DockPanel.Dock="Bottom"
              Padding="16,10"
              Background="{DynamicResource MaterialDesignPaper}">
        <DockPanel>
          <StackPanel DockPanel.Dock="Right"
                      Orientation="Horizontal">
            <Button Content="Previous"
                    Command="{Binding PreviousSlideCommand}"
                    Margin="0,0,8,0" />
            <Button Content="Next"
                    Command="{Binding AdvanceSlideCommand}"
                    Margin="0,0,8,0" />
            <Button Content="Go to Selected"
                    Command="{Binding GoToSelectedSlideCommand}" />
          </StackPanel>
          <TextBlock Text="{Binding CurrentSlideTitle}"
                     VerticalAlignment="Center"
                     TextTrimming="CharacterEllipsis" />
        </DockPanel>
      </Border>

      <DataGrid Margin="0"
                ItemsSource="{Binding Slides}"
                SelectedItem="{Binding SelectedSlide, Mode=TwoWay}"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                IsReadOnly="True"
                SelectionMode="Single">
        <DataGrid.Columns>
          <DataGridTextColumn Header="#"
                              Binding="{Binding SlideNumber}"
                              Width="50" />
          <DataGridTextColumn Header="Title"
                              Binding="{Binding Title}"
                              Width="200" />
          <DataGridTextColumn Header="Prompt"
                              Binding="{Binding PromptPreview}"
                              Width="*" />
        </DataGrid.Columns>
      </DataGrid>

    </DockPanel>
  </materialDesign:Card>
</UserControl>

<Window x:Class="Keboo.VocalSlide.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Keboo.VocalSlide"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=local:MainWindowViewModel, IsDesignTimeCreatable=False}"
        Style="{StaticResource MaterialDesignWindow}"
        Title="VocalSlide PowerPoint Auto Advance"
        Height="900"
        Width="1440"
        MinWidth="1200"
        MinHeight="780">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="220" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="420" />
      <ColumnDefinition Width="12" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <Border Grid.Row="0"
            Grid.ColumnSpan="3"
            Padding="16"
            Margin="0,0,0,16"
            Background="{DynamicResource MaterialDesignPaper}">
      <DockPanel LastChildFill="True">
        <WrapPanel DockPanel.Dock="Left"
                   VerticalAlignment="Center">
          <Button Content="Refresh PowerPoint"
                  Command="{Binding RefreshPowerPointCommand}"
                  Margin="0,0,8,0" />
          <Button Content="Start Listening"
                  Command="{Binding StartAutomationCommand}"
                  Margin="0,0,8,0" />
          <Button Content="Stop Listening"
                  Command="{Binding StopAutomationCommand}"
                  Margin="0,0,8,0" />
          <Button Content="Previous Slide"
                  Command="{Binding PreviousSlideCommand}"
                  Margin="0,0,8,0" />
          <Button Content="Next Slide"
                  Command="{Binding AdvanceSlideCommand}"
                  Margin="0,0,8,0" />
          <Button Content="Go To Selected Slide"
                  Command="{Binding GoToSelectedSlideCommand}"
                  Margin="0,0,8,0" />
          <Button Content="Clear Transcript"
                  Command="{Binding ClearTranscriptCommand}"
                  Margin="0,0,16,0" />
          <CheckBox Content="Auto-advance enabled"
                    IsChecked="{Binding IsAutoAdvanceEnabled, Mode=TwoWay}"
                    VerticalAlignment="Center" />
        </WrapPanel>

        <TextBlock Text="{Binding StatusMessage}"
                   TextWrapping="Wrap"
                   VerticalAlignment="Center" />
      </DockPanel>
    </Border>

    <GroupBox Grid.Row="1"
              Grid.Column="0"
              Header="Local models and session settings"
              Margin="0,0,0,16">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12">
          <TextBlock FontWeight="SemiBold"
                     Text="Model storage folder" />
          <TextBlock Margin="0,4,0,8"
                     Text="Downloaded model files are stored in %LOCALAPPDATA%\Keboo.VocalSlide."
                     TextWrapping="Wrap" />
          <DockPanel Margin="0,0,0,12">
            <Button DockPanel.Dock="Right"
                    Content="Open Folder"
                    Command="{Binding OpenModelFolderCommand}"
                    Margin="8,0,0,0" />
            <TextBox Text="{Binding ModelStorageDirectory}"
                     IsReadOnly="True" />
          </DockPanel>

          <TextBlock FontWeight="SemiBold"
                     Text="Whisper download" />
          <ComboBox Margin="0,4,0,4"
                    ItemsSource="{Binding WhisperDownloadOptions}"
                    SelectedItem="{Binding SelectedWhisperDownloadOption}"
                    DisplayMemberPath="DisplayName" />
          <DockPanel Margin="0,0,0,4">
            <Button DockPanel.Dock="Right"
                    Content="Download Whisper"
                    Command="{Binding DownloadWhisperModelCommand}"
                    Margin="8,0,0,0" />
            <TextBox Text="{Binding WhisperModelPath, UpdateSourceTrigger=PropertyChanged}" />
          </DockPanel>
          <TextBlock Text="{Binding WhisperDownloadStatus}"
                     TextWrapping="Wrap" />
          <ProgressBar Height="8"
                       Minimum="0"
                       Maximum="100"
                       Value="{Binding WhisperDownloadPercent}"
                       Margin="0,4,0,12" />

          <TextBlock FontWeight="SemiBold"
                     Text="LLM GGUF download" />
          <TextBox Margin="0,4,0,4"
                   Text="{Binding LlmDownloadUrl, UpdateSourceTrigger=PropertyChanged}" />
          <DockPanel Margin="0,0,0,4">
            <Button DockPanel.Dock="Right"
                    Content="Download GGUF"
                    Command="{Binding DownloadLlmModelCommand}"
                    Margin="8,0,0,0" />
            <TextBox Text="{Binding LlmModelPath, UpdateSourceTrigger=PropertyChanged}" />
          </DockPanel>
          <TextBlock Text="{Binding LlmDownloadStatus}"
                     TextWrapping="Wrap" />
          <ProgressBar Height="8"
                       Minimum="0"
                       Maximum="100"
                       Value="{Binding LlmDownloadPercent}"
                       Margin="0,4,0,12" />

          <Separator Margin="0,0,0,12" />

          <TextBlock FontWeight="SemiBold"
                     Text="Inference settings" />

          <TextBlock Margin="0,8,0,0"
                     Text="Transcript language" />
          <TextBox Margin="0,4,0,8"
                   Text="{Binding TranscriptionLanguage, UpdateSourceTrigger=PropertyChanged}" />

          <TextBlock Text="Indexed prompt slides" />
          <TextBox Margin="0,4,0,8"
                   Text="{Binding IndexedPromptSlideCount}"
                   IsReadOnly="True" />

          <TextBlock Text="Confidence threshold" />
          <TextBox Margin="0,4,0,8"
                   Text="{Binding ConfidenceThreshold, UpdateSourceTrigger=PropertyChanged}" />

          <TextBlock Text="Cooldown seconds" />
          <TextBox Margin="0,4,0,8"
                   Text="{Binding DecisionCooldownSeconds, UpdateSourceTrigger=PropertyChanged}" />

          <UniformGrid Columns="2">
            <StackPanel Margin="0,0,8,0">
              <TextBlock Text="LLM context size" />
              <TextBox Margin="0,4,0,0"
                       Text="{Binding LlmContextSize, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Margin="8,0,0,0">
              <TextBlock Text="GPU layers" />
              <TextBox Margin="0,4,0,0"
                       Text="{Binding LlmGpuLayerCount, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
          </UniformGrid>
        </StackPanel>
      </ScrollViewer>
    </GroupBox>

    <GroupBox Grid.Row="1"
              Grid.Column="2"
              Header="Presentation status"
              Margin="0,0,0,16">
      <Grid Margin="12">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="16" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0"
                   Grid.Column="0"
                   FontWeight="SemiBold"
                   Text="Presentation" />
        <TextBlock Grid.Row="0"
                   Grid.Column="2"
                   Text="{Binding PresentationName}" />

        <TextBlock Grid.Row="1"
                   Grid.Column="0"
                   FontWeight="SemiBold"
                   Text="Connection" />
        <TextBlock Grid.Row="1"
                   Grid.Column="2"
                   Text="{Binding ConnectionSummary}"
                   TextWrapping="Wrap" />

        <TextBlock Grid.Row="2"
                   Grid.Column="0"
                   FontWeight="SemiBold"
                   Text="Slide show" />
        <TextBlock Grid.Row="2"
                   Grid.Column="2"
                   Text="{Binding SlideShowStateText}" />

        <TextBlock Grid.Row="3"
                   Grid.Column="0"
                   FontWeight="SemiBold"
                   Text="Current slide" />
        <StackPanel Grid.Row="3"
                    Grid.Column="2">
          <TextBlock Text="{Binding CurrentSlideTitle}"
                     FontWeight="SemiBold" />
          <TextBlock Text="{Binding CurrentSlidePrompt}"
                     TextWrapping="Wrap"
                     Margin="0,4,0,0" />
        </StackPanel>

        <TextBlock Grid.Row="4"
                   Grid.Column="0"
                   FontWeight="SemiBold"
                   Text="Nearest indexed prompt" />
        <StackPanel Grid.Row="4"
                    Grid.Column="2">
          <TextBlock Text="{Binding NextSlideTitle}"
                     FontWeight="SemiBold" />
          <TextBlock Text="{Binding NextSlidePrompt}"
                     TextWrapping="Wrap"
                     Margin="0,4,0,0" />
        </StackPanel>
      </Grid>
    </GroupBox>

    <GroupBox Grid.Row="2"
              Grid.Column="0"
              Header="Live transcript window">
      <TextBox Margin="12"
               Text="{Binding TranscriptWindow}"
               TextWrapping="Wrap"
               VerticalScrollBarVisibility="Auto"
               IsReadOnly="True"
               AcceptsReturn="True" />
    </GroupBox>

    <GroupBox Grid.Row="2"
              Grid.Column="2"
              Grid.RowSpan="2"
              Header="Slides and automation prompts">
      <DataGrid Margin="12"
                ItemsSource="{Binding Slides}"
                SelectedItem="{Binding SelectedSlide, Mode=TwoWay}"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                IsReadOnly="True"
                SelectionMode="Single">
        <DataGrid.Columns>
          <DataGridTextColumn Header="#"
                              Binding="{Binding SlideNumber}"
                              Width="60" />
          <DataGridTextColumn Header="Title"
                              Binding="{Binding Title}"
                              Width="220" />
          <DataGridTextColumn Header="Prompt"
                              Binding="{Binding PromptPreview}"
                              Width="*" />
        </DataGrid.Columns>
      </DataGrid>
    </GroupBox>

    <GroupBox Grid.Row="3"
              Grid.Column="0"
              Header="Latest decision"
              Margin="0,16,0,0">
      <TextBox Margin="12"
               Text="{Binding LastDecision}"
               TextWrapping="Wrap"
               VerticalScrollBarVisibility="Auto"
               AcceptsReturn="True"
               IsReadOnly="True" />
    </GroupBox>
  </Grid>
</Window>
